# Required: Google AI API key for Gemini LLM and (optionally) Gemini embeddings
GOOGLE_API_KEY=your-google-api-key-here

# Optional: OpenAI API key (only needed if using OpenAI models)
# OPENAI_API_KEY=your-openai-api-key-here

# Optional: Embedding model selection — "minilm" (local, default) or "gemini" (API)
# EMBEDDING_MODEL=minilm

# Optional: Use ONNX Runtime for faster CPU inference (default: true)
# USE_ONNX=true

# Optional: Comma-separated list of allowed CORS origins (default: * for development)
# ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com
